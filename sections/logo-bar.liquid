{%- style -%}
  {% if section.settings.head_space %}
    .section-{{ section.id }}-padding .title-wrapper-with-link {
      padding: 10px 20px;
    }
  {% endif %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 991px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
    }
  }

  .logo-bar-item {
    height: auto;
    border-radius: 50%;
    border: 1px solid #1d2e40;
    overflow: hidden;
    padding: 0;
    aspect-ratio: 1 / 1;
    box-sizing: border-box;
  }

  .logo-bar__image {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .wblogos-wrapper__container {
    padding: 0 5rem;
    padding-top: 36px;
    padding-bottom: 36px;
    padding-left: 5rem;
    padding-right: 5rem;
  }

  .log-btn {
    position: absolute;
    z-index: 1;
    top: 50px;
    width: 25px !important;
    height: 25px !important;
    border-radius: 100%;
  }

  .log-btn span svg {
    width: 10px !important;
    height: 10px !important;
  }

  .log-btn.slider-button.slider-button--prev {
    left: -60px;
  }

  .log-btn.slider-button.slider-button--next {
    right: -60px;
  }

  .logo-bar-section {
    padding: 0px 20px;
  }

  @media screen and (max-width: 1199px) {
    .log-btn {
      top: 30px;
    }

    .logo-bar__container {
      gap: 0px !important;
      column-gap: 0px !important;
      row-gap: 0px !important;
    }
  }

  @media screen and (max-width: 750px) {
    .logo-bar-item {
      width: 82.25px;
      margin-right: 12px !important;
    }

    .wblogos-wrapper__container {
      margin: 0 auto;
      padding-top: 27px;
      padding-bottom: 27px;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .log-btn.slider-button.slider-button--prev {
      left: -30px;
    }

    .log-btn.slider-button.slider-button--next {
      right: -30px;
    }

    .log-btn {
      top: 20px;
    }

    .logo-bar-section {
      padding: 0px;
    }
  }

  @media screen and (max-width: 450px) {
    .logo-bar-item {
      width: 57.25px;
      margin-right: 12px !important;
    }
  }

  @media screen and (min-width: 1200px) {
    .logo-bar-item {
      width: calc(12.4% - var(--grid-desktop-horizontal-spacing) * 5 / 6) !important;
    }
  }
{%- endstyle -%}
{%- liquid
  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider
    assign show_desktop_slider = true
  endif 
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile
    assign show_mobile_slider = true
  endif
-%}
<div
  id="logo-bar-{{ section.id }}"
  class="wblogosd color-{{ section.settings.color_scheme }} {% if section.settings.secondary_background %}background-secondary{% else %} gradient{% endif %} {% unless section.settings.full_width %} page-width {% endunless %}"
>
  <div class="page-width">
    <div class="wblogos wblogos-wrapper__container section-{{ section.id }}-padding {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <slideshow-component>
        <div class="{{ section.settings.head_align }} title-wrapper-with-link {% if section.settings.heading != blank or section.settings.auto_rotate == false %}title-wrapper{% endif %} content-container color-{{ section.settings.heading_color_scheme }}{% if section.settings.heading == blank or section.settings.auto_rotate == true %} heading_part_disable{% endif %}">
          {% if section.settings.heading != blank %}
            <div class="heading inline-richtext">
              <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
            </div>
          {% endif %}
          <div class="wb_button_combo bcombo_auto" style="justify-content: space-between; width: 100%;">
            <div class="wb_home_sbtn slider-buttons no-js-hidden" style="justify-content: space-between; width: 100%;">
              <button
                type="button"
                class="log-btn slider-button slider-button--prev button"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
                aria-controls="Slider-{{ section.id }}"
                data-logo-prev
              >
                <span>{% render 'icon-caret' %}</span>
              </button>
              <button
                type="button"
                class="log-btn slider-button slider-button--next button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
                aria-label="{{ 'general.slider.next_slide' | t }}"
                aria-controls="Slider-{{ section.id }}"
                data-logo-next
              >
                <span>{% render 'icon-caret' %}</span>
              </button>
            </div>
          </div>
        </div>
        <div class="logo-bar-section color-{{ section.settings.color_scheme }} gradient">
          <div
            class="logo-bar__container grid--{{ section.settings.columns_desktop }}-col-desktop allslideprt grid {% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet {% endif %}{% endif %}"
            id="Slider-{{ section.id }}"
            {% if show_mobile_slider or show_desktop_slider %}
              data-autoplay="{{ section.settings.auto_rotate }}" data-speed="{{ section.settings.change_slides_speed }}"
            {% endif %}
            aria-live="polite"
            aria-atomic="true"
          >
            {%- for block in section.blocks -%}
              <div
                class="logo-bar-item {% if block.settings.image == blank %} placeholder-image {% endif %}grid__item slideshow__slide slider__slide {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    title="{{ 'wbcustomlabel.wballtext.banner' | t }}"
                    class="focus-inset"
                  >
                {%- endif %}
                {% if block.settings.image != blank %}
                  {%- liquid
                    assign widths = block.settings.image.width
                  -%}
                  <img
                    loading="lazy"
                    src="{{ block.settings.image | image_url: width: widths }}"
                    height="{{ block.settings.image.height }}"
                    width="{{ block.settings.image.width }}"
                    class="logo-bar__image img-fluid lazyload global-media-settings"
                    alt="{{ block.settings.image.alt }}"
                  >
                {% else %}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'product-apparel-' | append: placeholder_image_index -%}
                  <div class="dummysvg">{{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {% endif %}
                {% if block.settings.link != blank %}</a>{% endif %}
                {%- if block.settings.logo_title != blank and section.settings.show_title == false -%}
                  <h3 class="logo-title">{{ block.settings.logo_title }}</h3>
                {%- endif %}
              </div>
            {%- endfor -%}
          </div>
        </div>
        {%- if section.blocks.size > 1 -%}
          <div class="slideshow__controls slider-buttons">
            {%- if section.settings.auto_rotate -%}
              <button
                type="button"
                class="focus-inset slideshow__autoplay hidden"
                aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
              >
                {{ 'sections.slideshow.pause_slideshow' | t }}
              </button>
            {%- endif -%}
          </div>
        {%- endif -%}
      </slideshow-component>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('logo-bar-{{ section.id }}');
    if (!section) return;

    var slider = section.querySelector('#Slider-{{ section.id }}');
    var prevBtn = section.querySelector('[data-logo-prev]');
    var nextBtn = section.querySelector('[data-logo-next]');

    if (!slider || !prevBtn || !nextBtn) return;

    var slides = Array.from(slider.querySelectorAll('.slider__slide'));
    if (!slides.length) return;

    // Distance between first two slides, used as step size
    var step =
      slides.length > 1
        ? Math.abs(slides[1].offsetLeft - slides[0].offsetLeft)
        : slider.clientWidth;

    function updateButtons() {
      var maxScrollLeft = slider.scrollWidth - slider.clientWidth;
      var scrollLeft = slider.scrollLeft;

      if (scrollLeft <= 1) {
        prevBtn.setAttribute('disabled', 'disabled');
      } else {
        prevBtn.removeAttribute('disabled');
      }

      if (scrollLeft >= maxScrollLeft - 1) {
        nextBtn.setAttribute('disabled', 'disabled');
      } else {
        nextBtn.removeAttribute('disabled');
      }
    }

    // Initial state: at the first logo
    updateButtons();

    prevBtn.addEventListener('click', function (event) {
      event.preventDefault();
      var newLeft = Math.max(slider.scrollLeft - step, 0);
      slider.scrollTo({ left: newLeft, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', function (event) {
      event.preventDefault();
      var maxScrollLeft = slider.scrollWidth - slider.clientWidth;
      var newLeft = Math.min(slider.scrollLeft + step, maxScrollLeft);
      slider.scrollTo({ left: newLeft, behavior: 'smooth' });
    });

    // Keep state in sync if user drags/scrolls manually
    slider.addEventListener('scroll', function () {
      updateButtons();
    });
  });
</script>
{% schema %}
{
  "name": "t:sections.logo_bar.name",
  "tag": "section",
  "class": "spaced-section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.video.settings.full_width.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.title"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
