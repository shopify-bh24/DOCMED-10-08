{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'footer-docmed.css' | asset_url | stylesheet_tag }}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  {{ 'component-localization-form.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }
  .marquee .marquee_inner-{{ section.id }}.marquee-child {
    padding: 0 {{ settings.mark_space }}px;
  }
  @media screen and (min-width: 768px) {
    .offer_marquee {
      max-width: {{ settings.mark_width }}%;
    }
  }
  {% if settings.marq_position == 'bottom-left' %}
    .offer_marquee { left: 20px; }
  {% elsif settings.marq_position == 'bottom-center' %}
    .offer_marquee { left: 50%; transform: translateX(-50%); }
  {% elsif settings.marq_position == 'bottom-right' %}
    .offer_marquee { right: 20px; }
  {% endif %}
  .marquee_inner-{{ section.id }} p {
    color: rgba(var(--color-foreground));
  }
  .marquee:hover .marquee_inner-{{ section.id }} {
    animation-play-state: paused !important;
    cursor: pointer;
  }
  @media (prefers-reduced-motion: no-preference) {
    .marquee_inner-{{ section.id }}.left_right {
      animation: translateLeft {{ settings.mark_speed }}s linear infinite;
    }
    .marquee_inner-{{ section.id }}.right_left {
      animation: translateRight {{ settings.mark_speed }}s linear infinite;
    }
  }
  @keyframes translateLeft {
    from { transform: translateX(-100%); }
    to   { transform: translateX(calc(100% * 1)); }
  }
  @keyframes translateRight {
    from { transform: translateX(100%); }
    to   { transform: translateX(calc(-100% * 1)); }
  }
{%- endstyle -%}

<div class="footer color-{{ section.settings.color_scheme }}">

  {%- comment -%} ========== HAUPT-FOOTER: 3-Spalten Grid ========== {%- endcomment -%}
  <div class="dm-footer__main">
    <div class="dm-footer__inner page-width">

      {%- comment -%} SPALTE 1: Logo + Kontakt + Versandpartner + Zertifikat {%- endcomment -%}
      <div class="dm-footer__brand">

        {%- comment -%} Logo aus Theme-Einstellungen {%- endcomment -%}
        {%- if section.settings.footer_logo != blank -%}
          {%- assign logo_alt = section.settings.footer_logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = section.settings['footer-logo_width']
            | divided_by: section.settings.footer_logo.aspect_ratio
            | round
          -%}
          <a href="{{ routes.root_url }}" class="dm-footer__logo-link">
            <img
              class="dm-footer__logo-img"
              srcset="{{ section.settings.footer_logo | image_url: width: 300 }}"
              src="{{ section.settings.footer_logo | image_url }}"
              alt="{{ logo_alt }}"
              height="{{ logo_height }}"
              width="{{ section.settings['footer-logo_width'] }}"
              loading="lazy"
            >
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="dm-footer__logo-link dm-footer__logo-text">
            {{ shop.name }}
          </a>
        {%- endif -%}

        {%- comment -%} Kontaktdaten aus brand_information Block {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand_information' -%}
            <div class="dm-footer__contact" {{ block.shopify_attributes }}>
              <p class="dm-footer__label">Ihr Kontakt zu uns</p>
              {%- if block.settings.footer_contact_no != blank -%}
                <p><strong><a href="tel:{{ block.settings.footer_contact_no | strip_html | remove: ' ' | remove: '–' | remove: '-' }}">{{ block.settings.footer_contact_no }}</a></strong></p>
              {%- endif -%}
              {%- if block.settings.footer_contact_id != blank -%}
                <p>{{ block.settings.footer_contact_id }}</p>
              {%- endif -%}
              {%- if block.settings.footer_address != blank -%}
                <p class="dm-footer__address">{{ block.settings.footer_address | newline_to_br }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Versandpartner-Logos {%- endcomment -%}
        <div class="dm-footer__shipping">
          <p class="dm-footer__label">Unsere Versandpartner</p>
          <div class="dm-footer__shipping-logos">
            <img src="{{ 'logo-dhl.svg' | asset_url }}" alt="DHL" width="60" height="36" loading="lazy">
            <img src="{{ 'logo-deutsche-post.svg' | asset_url }}" alt="Deutsche Post" width="36" height="36" loading="lazy">
            <img src="{{ 'logo-gls.svg' | asset_url }}" alt="GLS" width="50" height="36" loading="lazy">
          </div>
        </div>

        {%- comment -%} DIMDI-Zertifikat aus image Block {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'image' -%}
            <div class="dm-footer__cert" {{ block.shopify_attributes }}>
              <a href="https://versandhandel.dimdi.de/websearch/servlet/Gate?accessid=dimdi_var&term=441b940d4ec7c01003d99a187a54edad"
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="Zur Überprüfung der Legalität dieser Website">
                <div style="position:relative; width:90px;">
                  <img
                    src="//versandhandel.dimdi.de/img/logo.png"
                    alt="Link zum Versandhandels-Register"
                    width="90"
                    loading="lazy"
                    style="width:100%; height:auto; display:block;"
                  >
                  <img
                    src="//versandhandel.dimdi.de/img/logo.gif"
                    alt=""
                    aria-hidden="true"
                    style="position:absolute; top:0; left:0; width:100%; height:auto;"
                  >
                </div>
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>

      {%- comment -%} SPALTEN 2 + 3: Link-Listen aus link_list Blöcken {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' and block.settings.menu != blank -%}
          <div class="dm-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="dm-footer__col-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            <ul class="dm-footer__col-list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}"{% if link.active %} class="dm-footer__link--active"{% endif %}>
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

  {%- comment -%} ── Lokalisierung + Policy-Links (unverändert) ── {%- endcomment -%}
  {% if section.settings.enable_language_selector
    or section.settings.enable_country_selector
    or section.settings.show_policy
    and shop.policies != blank
  %}
    <div class="footer__content-bottom">
      <div class="footer__content-bottom-wrapper page-width">
        {%- if section.settings.show_policy != blank and shop.policies != blank -%}
          <div class="footer__column footer__column--info">
            <ul class="policies list-unstyled">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                  <li>
                    <small class="copyright__content"><a href="{{ policy.url }}">{{ policy.title }}</a></small>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
          <div class="footer__column followonshop">
            <div class="footer__follow-on-shop">
              {% # theme-check-disable %}
              {{ shop | login_button: action: 'follow' }}
              {% # theme-check-enable %}
            </div>
          </div>
        {%- endif -%}
        {% if section.settings.enable_country_selector or section.settings.enable_language_selector %}
          <div class="footer__column footer__localization isolate">
            {% if section.settings.localization_heading != blank %}
              <div class="h4">{{ section.settings.localization_heading }}</div>
            {% endif %}
            <div>
              {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                <noscript>
                  {%- form 'localization', id: 'FooterLanguageFormNoScript', class: 'localization-form' -%}
                    <div class="localization-form__select">
                      <select class="localization-selector link" name="locale_code" tabindex="0" aria-labelledby="FooterLanguageLabelNoScript">
                        {%- for language in localization.available_languages -%}
                          <option tabindex="-1" value="{{ language.iso_code }}" lang="{{ language.iso_code }}"
                            {%- if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                            {{ language.endonym_name | capitalize }}
                          </option>
                        {%- endfor -%}
                      </select>
                      {% render 'icon-caret' %}
                    </div>
                    <button class="button button--tertiary" tabindex="0">{{ 'localization.update_language' | t }}</button>
                  {%- endform -%}
                </noscript>
                <localization-form tabindex="-1">
                  {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                    <div class="no-js-hidden">
                      {%- render 'language-localization', full_form: false, localPosition: 'FooterLanguage' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              {%- endif -%}
              {% if section.settings.enable_language_selector and section.settings.enable_country_selector %}
                <div class="footer_localization_separator" tabindex="-1"></div>
              {% endif %}
              {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                <noscript>
                  {%- form 'localization', id: 'FooterCountryFormNoScript', class: 'localization-form' -%}
                    <div class="localization-form__select">
                      <select class="localization-selector link" name="country_code" tabindex="0">
                        {%- for country in localization.available_countries -%}
                          <option tabindex="-1" value="{{ country.iso_code }}"
                            {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                            {{ country.currency.iso_code }} {{ country.currency.symbol }}
                          </option>
                        {%- endfor -%}
                      </select>
                      {% render 'icon-caret' %}
                    </div>
                    <button class="button button--tertiary" tabindex="0">{{ 'localization.update_country' | t }}</button>
                  {%- endform -%}
                </noscript>
                <localization-form tabindex="-1">
                  {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                    <div class="no-js-hidden">
                      {%- render 'country-localization', full_form: false, localPosition: 'FooterCountry' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              {%- endif -%}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {%- comment -%} ── Copyright + Zahlungsarten (unverändert) ── {%- endcomment -%}
  {% if section.settings.show_copyright or section.settings.payment_enable %}
    <div class="footer_copyright_wrapper{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="caption page-width footer__content-bottom-wrapper">
        {%- if section.settings.show_copyright -%}
          <div class="footer__column footer_bottom_copyright">
            <small class="copyright__content">
              <span>&copy; {{ 'now' | date: '%Y' }},</span> {{ shop.name | link_to: routes.root_url }}&nbsp;
            </small>
            <small class="copyright__content">{{ powered_by_link }}</small>
          </div>
        {%- endif -%}
        {%- if section.settings.payment_enable -%}
          <div class="footer__column footer__payment footer_bottom_copyright">
            <ul class="list list-payment">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {%- comment -%} ── Scroll-to-top (unverändert) ── {%- endcomment -%}
  {%- if section.settings['scroll-to-top'] -%}
    <a
      class="scroll_to_top scroll-progress{% if settings.show_marquee == true and settings.marq_position == 'bottom-right' %} marq_right{% endif %}"
      id="scroll"
      style="display: block;"
      onclick="scrollToTop()"
      title="{{ 'wbcustomlabel.wballtext.scrolltop' | t }}"
    >
      <span id="progress-value">{% render 'icon-double-arrow-up' %}</span>
    </a>
  {%- endif -%}

  {%- comment -%} ── Marquee (unverändert) ── {%- endcomment -%}
  {% if settings.show_marquee %}
    <div class="offer_marquee gradient color-{{ settings.marq_color_scheme }}">
      <div class="marquee marquee_inner-{{ section.id }}">
        {%- for i in (1..20) -%}
          <div class="marquee-child marquee_inner-{{ section.id }} {% if settings.marq_diection == 'left_right' %}left_right{% else %}right_left{% endif %}">
            {% if settings.marq_image != blank %}
              {{ settings.marq_image | image_url: width: 30 | image_tag: loading: 'lazy' }}
            {% endif %}
            <p>
              {% if settings.marq_image == blank %}
                {% if settings.show_emoji == 'smile' %}{%- assign emoji = '&#x1F60A;' -%}{{ emoji }}
                {% elsif settings.show_emoji == 'heart_eye' %}{%- assign emoji = '&#128525;' -%}{{ emoji }}
                {% elsif settings.show_emoji == 'star' %}{%- assign emoji = '&#11088;' -%}{{ emoji }}
                {% elsif settings.show_emoji == 'celebration' %}{%- assign emoji = '&#127881;' -%}{{ emoji }}
                {% elsif settings.show_emoji == 'gift' %}{%- assign emoji = '&#127873;' -%}{{ emoji }}
                {% endif %}
              {% endif %}
              {% if settings.marq_link != blank %}
                <a href="{{ settings.marq_link }}">{{ settings.marq_text }}</a>
              {% else %}
                {{ settings.marq_text }}
              {% endif %}
            </p>
          </div>
        {%- endfor -%}
      </div>
      <div class="close_offer">{% render 'icon-close' %}</div>
    </div>
  {% endif %}

</div>

{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script>
  document.querySelectorAll('.close_offer').forEach(function(el) {
    el.addEventListener('click', function() {
      var div = document.querySelector('.offer_marquee');
      if (div) div.remove();
    });
  });
</script>

{%- if section.settings['scroll-to-top'] -%}
<script>
  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function updateScrollProgress() {
    var scrollProgress = document.getElementById('scroll');
    if (!scrollProgress) return;
    var pos = window.scrollY || document.documentElement.scrollTop;
    var calcHeight = document.documentElement.scrollHeight - window.innerHeight;
    var scrollValue = Math.round((pos * 100) / calcHeight);
    if (calcHeight > 0) {
      scrollProgress.style.display = pos > 100 ? 'grid' : 'none';
      scrollProgress.style.setProperty('--scroll-value', scrollValue + '%');
    }
  }
  document.addEventListener('DOMContentLoaded', function() {
    updateScrollProgress();
    var scrollProgress = document.getElementById('scroll');
    if (scrollProgress) {
      window.addEventListener('scroll', updateScrollProgress);
      window.addEventListener('resize', updateScrollProgress);
    }
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "footer",
  "max_blocks": 5,
  "blocks": [
    { "type": "@app" },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
