   DocMed Footer â€“ Altruan Style
   Datei: assets/footer-docmed.css
   In theme.liquid einbinden:
   {{ 'footer-docmed.css' | asset_url | stylesheet_tag }}
   ============================================================ */

/* â”€â”€ Wrapper â”€â”€ */
.docmed-footer {
  background-color: #ffffff;
  border-top: 1px solid #e8e8e8;
  font-family: inherit;
  color: #333333;
}

/* â”€â”€ Grid: 3 Spalten (Brand | Service | GmbH) â”€â”€ */
.docmed-footer__inner {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr;
  gap: 3rem;
  max-width: 1280px;
  margin: 0 auto;
  padding: 3rem 2rem 2.5rem;
}

/* â”€â”€ Spalte 1: Brand â”€â”€ */
.docmed-footer__brand {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.docmed-footer__logo-link {
  display: inline-block;
  text-decoration: none;
}

.docmed-footer__logo-img {
  max-width: 160px;
  height: auto;
  display: block;
}

.docmed-footer__logo-text {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.5px;
  color: #1a2e4a;
}

/* â”€â”€ Kontaktblock â”€â”€ */
.docmed-footer__contact {
  display: flex;
  flex-direction: column;
  gap: 2px;
  font-size: 13.5px;
  line-height: 1.8;
  color: #555555;
}

.docmed-footer__contact p {
  margin: 0;
}

.docmed-footer__contact-label {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #999999;
  margin-bottom: 4px !important;
}

.docmed-footer__contact strong {
  font-weight: 600;
  color: #222222;
}

.docmed-footer__contact a {
  color: inherit;
  text-decoration: none;
}

.docmed-footer__contact a:hover {
  color: #1a2e4a;
  text-decoration: underline;
}

.docmed-footer__address {
  margin-top: 6px !important;
  line-height: 1.7;
}

/* â”€â”€ Versandpartner â”€â”€ */
.docmed-footer__shipping {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.docmed-footer__shipping-label {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #999999;
  margin: 0;
}

.docmed-footer__shipping-logos {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.docmed-footer__shipping-logos img {
  height: 36px;
  width: auto;
  object-fit: contain;
  border-radius: 6px;
}

/* â”€â”€ DIMDI-Zertifikat â”€â”€ */
.docmed-footer__cert {
  margin-top: 4px;
}

.docmed-footer__cert a {
  display: inline-block;
}

/* â”€â”€ Link-Spalten â”€â”€ */
.docmed-footer__col {
  display: flex;
  flex-direction: column;
}

.docmed-footer__col-heading {
  font-size: 13.5px;
  font-weight: 600;
  color: #111111;
  margin: 0 0 14px;
  letter-spacing: 0.01em;
}

.docmed-footer__col-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.docmed-footer__col-list li a {
  font-size: 13.5px;
  color: #555555;
  text-decoration: none;
  transition: color 0.15s ease;
}

.docmed-footer__col-list li a:hover {
  color: #111111;
}

/* â”€â”€ Bottom Bar â”€â”€ */
.docmed-footer__bottom {
  border-top: 1px solid #e8e8e8;
  max-width: 1280px;
  margin: 0 auto;
  padding: 1.1rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.docmed-footer__legal {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 20px;
}

.docmed-footer__legal a {
  font-size: 12px;
  color: #888888;
  text-decoration: none;
  transition: color 0.15s ease;
}

.docmed-footer__legal a:hover {
  color: #333333;
}

.docmed-footer__copy {
  font-size: 12px;
  color: #888888;
  margin: 0;
  white-space: nowrap;
}

/* â”€â”€ Responsive: Tablet â”€â”€ */
@media (max-width: 900px) {
  .docmed-footer__inner {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .docmed-footer__brand {
    grid-column: 1 / -1;
  }
}

/* â”€â”€ Responsive: Mobile â”€â”€ */
@media (max-width: 600px) {
  .docmed-footer__inner {
    grid-template-columns: 1fr;
    padding: 2rem 1.25rem 1.5rem;
    gap: 1.75rem;
  }

  .docmed-footer__bottom {
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 1.25rem;
  }

  .docmed-footer__copy {
    order: -1;
  }
}